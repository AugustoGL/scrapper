{
    "manifest_version": 3,
    "name": "AI Scraper",
    "version": "1.0.0",
    "description": "Extractor de datos web con IA",
    "action": {
        "default_popup": "popup.html"
    },
    "permissions": [
        "activeTab",
        "scripting",
        "tabs"
    ],
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "content.js"
            ]
        }
    ],
    "host_permissions": [
        "<all_urls>",
        "http://localhost:*/*"
    ],
    "web_accessible_resources": [
  {
    "resources": ["viewer.html"],
    "matches": ["<all_urls>"]
  }
]
}