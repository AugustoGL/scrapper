
erDiagram

    User ||--o{ Table: has
    Table ||--o{ Column: has
    Table ||--o{ Record: has
    Record ||--o{ Value: has
    Column ||--o{ Value: has


    User {
        int id_user PK
        string username
        string email
        string password
    }

    Table {
        int id_table PK
        string name
        date creation_at
        int id_user FK
    }

    Column {
        int column_id PK
        string name
        string data_type
        int id_table FK
    }

    Record {
        int id_record PK
        date creation_at
        int id_table FK
    }

    Value {
        int id_value PK
        string value
        int id_record FK
        int id_column FK
    }